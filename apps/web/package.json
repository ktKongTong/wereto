{
  "name": "@apps/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "check": "react-router typegen && tsgo -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate && pnpm run db:sync",
    "db:sync": "node scripts/sync-d1-migrations.ts",
    "db:push": "drizzle-kit push",
    "migration": "wrangler --config=../../wrangler.jsonc d1 migrations apply DB",
    "migration:remote": "wrangler --config=../../wrangler.jsonc d1 migrations apply DB --remote",
    "deploy": "pnpm run migration:remote && wrangler deploy --config=./build/server/wrangler.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-router/node": "^7.15.1",
    "@repo/weread-api": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "1.0.0-rc.1",
    "hono": "^4.12.19",
    "isbot": "^5.1.31",
    "lucide-react": "^0.542.0",
    "p-limit": "catalog:",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.76.0",
    "react-router": "^7.15.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:worker",
    "@cloudflare/workers-types": "catalog:worker",
    "@react-router/dev": "^7.15.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "1.0.0-rc.1",
    "react-router-hono-server": "^2.26.0",
    "tailwindcss": "4.3.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4.92.0"
  }
}
