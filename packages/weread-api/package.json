{
  "name": "@repo/weread-api",
  "version": "0.1.0",
  "description": "Typed WeRead API wrapper built on fetch and ky.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && rolldown -c",
    "check": "tsgo -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "weread",
    "api-client"
  ],
  "license": "MIT",
  "dependencies": {
    "ky": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rolldown": "catalog:",
    "typescript": "catalog:"
  }
}
